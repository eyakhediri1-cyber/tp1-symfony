{% extends 'base.html.twig' %}

{% block title %}{{ tache.titre }}{% endblock %}

{% block body %}
    <h1>{{ tache.titre }}</h1>

    <p>{{ tache.description }}</p>

    <p>
        Statut :
        {% if tache.terminee %}✅ Terminée{% else %} En cours{% endif %}
    </p>

    <p>Créée le : {{ tache.dateCreation|date('d/m/Y') }}</p>

    <a href="{{ path('app_taches') }}">← Retour à la liste</a>
{% endblock %}